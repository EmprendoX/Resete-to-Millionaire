{
  "name": "reset-to-millionaire",
  "version": "0.3.0",
  "description": "Reset to Millionaire — desktop affirmations and binaural sessions (Electron)",
  "main": "electron/main.js",
  "scripts": {
    "dev:react": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.js",
    "dev": "electron electron/main.js",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "preview": "npm run build && electron .",
    "start": "npm run dev",
    "lint": "eslint . --ext ts,tsx",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "mobile:dev": "node server.js",
    "mobile:build": "node mobile/build.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.1",
    "cross-env": "^7.0.3",
    "electron": "^29.3.0",
    "electron-builder": "^26.0.12",
    "electron-icon-maker": "^0.0.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.resettomillionaire.app",
    "productName": "Reset to Millionaire",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "control.html",
      "control.css",
      "overlay.html",
      "index.html",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icons/mac/icon.icns",
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "icon": "assets/icons/win/icon.ico",
      "target": "nsis"
    },
    "dmg": {
      "title": "Reset to Millionaire",
      "background": null
    }
  }
}
